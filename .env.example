# این فایل را کپی کن به ".env" (کنار همین فایل، در ریشه‌ی پروژه) و مقدارهای زیر را عوض کن.
# docker-compose خودش این متغیرها را می‌خواند و به سرویس backend می‌دهد.
#
# معماری: بات تلگرام روی یک سرور جدا (با دسترسی مستقیم به تلگرام) اجرا می‌شود — پوشه‌ی
# telegram-bot/. این بک‌اند (روی این سرور) فقط FastAPI + دیتابیس است و از طریق مسیرهای
# /internal/* با سرویس بات صحبت می‌کند.

# برای امضای توکن‌های JWT (لاگین پنل وب) استفاده می‌شود.
# قبل از هر اجرای واقعی روی سرور، این را با یک رشته‌ی تصادفی و طولانی عوض کن؛ هرگز آن را عمومی/در گیت‌هاب قرار نده.
# یک مقدار تصادفی در PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 40 | % {[char]$_})
SECRET_KEY=REPLACE-THIS-WITH-A-LONG-RANDOM-SECRET-VALUE

# کلید مشترک بین این بک‌اند و سرویس بات (telegram-bot/) برای مسیرهای /internal/*.
# باید دقیقاً همین مقدار در .env سرویس بات هم ست شود. هرگز آن را عمومی/در گیت‌هاب قرار نده.
INTERNAL_API_KEY=REPLACE-THIS-WITH-A-LONG-RANDOM-SHARED-SECRET

# آدرس سرویس بات (که روی سرور دیگری با دسترسی مستقیم به تلگرام اجرا می‌شود)، برای اینکه
# این بک‌اند بتواند یادآوری تسک‌ها را برای ارسال به آن بسپارد. اگر خالی باشد، یادآوری‌ها غیرفعال می‌مانند.
GERMANY_RELAY_URL=http://IP-سرور-بات:8090

# --- اختیاری: همگام‌سازی خودکار تسک‌ها از گوگل‌شیت تیم ---
# آدرس export CSV شیت (باید با «هرکسی که لینک را دارد» قابل مشاهده باشد). اگر خالی باشد،
# سینک غیرفعال می‌ماند. نگاشت اسم owner به یوزرنیم تلگرام در backend/sheet_sync.py است.
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=csv&gid=GID
