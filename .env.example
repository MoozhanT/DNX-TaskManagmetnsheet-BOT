# این فایل را کپی کن به ".env" (کنار همین فایل، در ریشه‌ی پروژه) و مقدارهای زیر را عوض کن.
# docker-compose خودش این متغیرها را می‌خواند و به سرویس backend می‌دهد.

# برای امضای توکن‌های JWT (لاگین پنل وب) استفاده می‌شود.
# قبل از هر اجرای واقعی روی سرور، این را با یک رشته‌ی تصادفی و طولانی عوض کن؛ هرگز آن را عمومی/در گیت‌هاب قرار نده.
# یک مقدار تصادفی در PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 40 | % {[char]$_})
SECRET_KEY=REPLACE-THIS-WITH-A-LONG-RANDOM-SECRET-VALUE

# توکن باتی که از @BotFather در تلگرام گرفته‌ای (دستور /newbot).
# بدون این مقدار، بک‌اند و پنل وب بالا می‌آیند ولی بات تلگرام و یادآوری‌ها غیرفعال می‌مانند.
TELEGRAM_BOT_TOKEN=REPLACE-THIS-WITH-YOUR-BOTFATHER-TOKEN
