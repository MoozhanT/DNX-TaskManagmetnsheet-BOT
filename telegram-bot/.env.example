# این فایل را کپی کن به ".env" کنار همین فایل و مقدارهای زیر را عوض کن.

# توکن باتی که از @BotFather در تلگرام گرفته‌ای
TELEGRAM_BOT_TOKEN=REPLACE-THIS-WITH-YOUR-BOTFATHER-TOKEN

# آدرس عمومی بک‌اند اصلی (سرور دیگر)، بدون اسلش انتهایی
IRAN_API_BASE_URL=https://dnxtask.mozhantehrani.com

# باید دقیقاً همان مقداری باشد که در .env بک‌اند اصلی برای INTERNAL_API_KEY ست شده
INTERNAL_API_KEY=REPLACE-THIS-WITH-THE-SAME-SHARED-SECRET-AS-BACKEND

# --- اختیاری: نوشتن تسک‌های ساخته‌شده با /addtask به تب «new task» گوگل‌شیت ---
# جزئیات نصب Apps Script در telegram-bot/apps_script_new_task.gs.txt آمده
# SHEET_APPEND_URL=آدرس-دیپلوی-اپ‌اسکریپت
# SHEET_APPEND_SECRET=همون-سکرتی-که-توی-اپ‌اسکریپت-گذاشتی
